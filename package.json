{
	"name": "mdconvwk",
	"type": "module",
	"packageManager": "pnpm@11",
	"engines": {
		"node": "24"
	},
	"scripts": {
		"dev": "wrangler dev",
		"deploy": "wrangler deploy --minify",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings",
		"test": "vitest",
		"test:ci": "vitest run",
		"lint": "oxlint --deny-warnings .",
		"lint:fix": "oxlint --deny-warnings . --fix",
		"fmt": "oxfmt --write src/ test/",
		"fmt:check": "oxfmt --check src/ test/",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"hono": "^4.8.12"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "0.16.14",
		"oxfmt": "0.54.0",
		"oxlint": "1.69.0",
		"oxlint-tsgolint": "0.23.0",
		"typescript": "6.0.3",
		"vite": "7.3.5",
		"vitest": "4.1.8",
		"wrangler": "4.99.0"
	}
}
