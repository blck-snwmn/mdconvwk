	},
	"dependencies": {
		"hono": "^4.8.12"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "0.8.71",
		"oxfmt": "^0.48.0",
		"oxlint": "^1.63.0",
		"oxlint-tsgolint": "^0.22.1",
		"typescript": "5.9.3",
		"vitest": "3.2.4",
		"wrangler": "4.59.3"
	}
}