{
	"name": "mdconvwk",
	"type": "module",
	"packageManager": "pnpm@11.13.1",
	"engines": {
		"node": "24"
	},
	"scripts": {
		"dev": "wrangler dev",
		"deploy": "wrangler deploy --minify",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings",
		"test": "vitest",
		"test:ci": "vitest run",
		"lint": "oxlint --deny-warnings .",
		"lint:fix": "oxlint --deny-warnings . --fix",
		"fmt": "oxfmt --write src/ test/",
		"fmt:check": "oxfmt --check src/ test/",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"hono": "^4.8.12"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "0.18.5",
		"oxfmt": "0.59.0",
		"oxlint": "1.74.0",
		"oxlint-tsgolint": "0.25.0",
		"typescript": "7.0.2",
		"vite": "8.1.5",
		"vitest": "4.1.10",
		"wrangler": "4.111.0"
	}
}
